# TaxApp — Production Environment Variables
# Copy this file to .env.production on the server and fill in all values.
# NEVER commit .env.production to git.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_64_char_hex_secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API
ALLOWED_ORIGINS=https://taxapp.wichtel.ai

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
